# Server
PORT=5002
BASE_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/cars

# JWT Secrets — use long random strings in production
JWT_SECRET=change_me_to_a_long_random_secret
ACCESS_TOKEN_SECRET=change_me_access_token_secret
REFRESH_TOKEN_SECRET=change_me_refresh_token_secret
USER_TYPE_TOKEN_SECRET=change_me_user_type_secret

# Payment — Razorpay (test keys for development)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Image Storage — ImageKit (optional; falls back to local disk if empty)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
